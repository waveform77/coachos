# Application
APP_ENV=development
APP_PORT=8080
APP_NAME=coachos-api

# JWT
JWT_SECRET=your-super-secret-key-must-be-at-least-32-characters-long
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Database
DB_HOST=localhost
# Если Postgres в Docker Compose — см. POSTGRES_HOST_PORT в docker-compose (по умолчанию хост 5433).
# Неверный порт (например 5432 при пробросе 5433) даёт чужой Postgres → ошибка пароля для user coachos.
DB_PORT=5433
# Должны совпадать с корневым .env для docker compose (POSTGRES_*). Том БД создаётся один раз;
# смена пароля только здесь не обновит уже инициализированный кластер — см. README (docker compose down -v).
DB_USER=coachos
DB_PASSWORD=coachos_secret
DB_NAME=coachos_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_EXPIRATION_SECONDS=60

# AI Provider
AI_PROVIDER=mock

# DeepSeek API (cheap AI provider: ~$0.14/M input, ~$0.28/M output tokens)
# Get key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
